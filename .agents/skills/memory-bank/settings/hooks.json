{
  "Setup": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "cat << 'CONTEXT'\n[SYSTEM] [memory-bank-skill] Read ~/.claude/CLAUDE.md before starting work.\nPrinciples: TDD · Testing Trophy · Contract-First · SOLID · DRY · KISS · YAGNI · Clean Architecture · Fail Fast\nMemory Bank: ./.memory-bank/ — if it exists, run /mb start or Agent(MB Manager, action: context) to load context.\nCONTEXT"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "echo '[PRE-WRITE] [memory-bank-skill] TDD · Contract-First · no TODO/placeholders · complete imports · comments in English · error handling'"
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/hooks/block-dangerous.sh # [memory-bank-skill]"
        }
      ]
    },
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/skills/memory-bank/hooks/mb-protected-paths-guard.sh # [memory-bank-skill]"
        },
        {
          "type": "command",
          "command": "~/.claude/skills/memory-bank/hooks/mb-ears-pre-write.sh # [memory-bank-skill]"
        }
      ]
    },
    {
      "matcher": "Task",
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/skills/memory-bank/hooks/mb-context-slim-pre-agent.sh # [memory-bank-skill]"
        },
        {
          "type": "command",
          "command": "~/.claude/skills/memory-bank/hooks/mb-sprint-context-guard.sh # [memory-bank-skill]"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/hooks/file-change-log.sh # [memory-bank-skill]"
        },
        {
          "type": "command",
          "command": "~/.claude/skills/memory-bank/hooks/mb-plan-sync-post-write.sh # [memory-bank-skill]"
        }
      ]
    },
    {
      "matcher": "Edit",
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/hooks/file-change-log.sh # [memory-bank-skill]"
        }
      ]
    }
  ],
  "Notification": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "osascript -e 'display notification \"Claude Code needs attention\" with title \"Claude Code\"' 2>/dev/null; true # [memory-bank-skill]"
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "echo '[COMPACTION] [memory-bank-skill] Before compaction, run MB Manager (Agent, model: sonnet) to actualize .memory-bank/ — checklist, progress, STATUS. Then preserve key principles from CLAUDE.md and the current task context.'"
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "if [ -d .memory-bank ]; then echo '[MEMORY BANK] [memory-bank-skill] Recommendation: /mb done — update checklist, create a note, append progress'; fi"
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/hooks/session-end-autosave.sh # [memory-bank-skill]"
        },
        {
          "type": "command",
          "command": "~/.claude/hooks/mb-compact-reminder.sh # [memory-bank-skill]"
        }
      ]
    }
  ]
}
